{
  "name": "shift-bruteforce",
  "version": "1.0.0",
  "description": "Professional Shift Cipher Brute Force Analyzer with React + Node.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "server": "cd server && npm start",
    "frontend": "cd frontend && npm run dev",
    "install-all": "npm install && cd frontend && npm install && cd ../server && npm install",
    "build": "cd frontend && npm run build"
  },
  "keywords": [
    "cryptography",
    "brute-force",
    "shift-cipher",
    "caesar-cipher",
    "cryptanalysis"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}